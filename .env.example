# Spotify API — required for /api/spotify/* endpoints
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add redirect URI: https://your-domain.vercel.app/api/spotify/callback
# 3. Visit /api/spotify/authorize in your browser to complete OAuth
# 4. Copy the refresh token from /api/spotify/callback into SPOTIFY_REFRESH_TOKEN
# 5. Delete api/spotify/authorize.ts + api/spotify/callback.ts after setup

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=https://your-domain.vercel.app/api/spotify/callback

# Frontend: points to the Vercel deployment (leave empty for same-origin)
VITE_API_BASE=
